# ---- Home-server sync configuration (copy to deploy/.env) ----

# Read side: the Teslalogger database (direct, on the Docker network).
TESLATECH_DB_MODE=direct
DB_HOST=teslalogger-db
DB_PORT=3306
DB_USER=teslalogger
DB_PASS=teslalogger
DB_NAME=teslalogger

# Privacy: secret salt for anonymized car ids. PIN THIS and keep it private.
# Generate once: python -c "import secrets;print(secrets.token_hex(16))"
TESLATECH_ANON_SALT=change-me-to-a-long-random-secret

# Publish target A: managed Postgres (Supabase / Neon). Holds the fleet artifact
# AND the public questionnaire submissions. The Streamlit app reads from here too.
TESLATECH_DB_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# Publish target B (optional): S3-compatible object storage (Cloudflare R2).
# Cheapest read path; set PUBLISH_TARGETS="postgres s3" to use it.
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_BUCKET=teslatech
# S3_KEY=fleet.json
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_BASE=https://pub-xxxx.r2.dev
